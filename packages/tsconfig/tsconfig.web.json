{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /* Let the bundler handle JSX compilation */
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "isolatedModules": true,

    /* vite/webpack tip */
    "allowJs": true,
    "noEmit": true
  }
}
